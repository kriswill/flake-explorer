{
  "name": "@kriswill/flake-explorer",
  "version": "0.5.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Interactive visualizer for Nix flakes: outputs/module tree, option provenance (defaulted vs customized), file map with git + flake.lock input info",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kriswill/flake-explorer.git"
  },
  "homepage": "https://github.com/kriswill/flake-explorer#readme",
  "keywords": [
    "nix",
    "flake",
    "flake-parts",
    "dendritic",
    "visualization",
    "svelte",
    "rust"
  ],
  "bin": {
    "flake-explorer": "bin/flake-explorer.mjs"
  },
  "files": [
    "bin/",
    "app-dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "docs:api": "typedoc",
    "docs:build": "bun scripts/build-docs.ts",
    "docs": "typedoc && bun scripts/build-docs.ts --out _site/docs --api .docs-api",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build:app": "bun scripts/bundle-app.ts",
    "lint:ci": "biome ci ."
  },
  "dependencies": {
    "bun-plugin-svelte": "^0.0.6",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "^1.3.14",
    "happy-dom": "^20.10.6",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "svelte-check": "^4.7.2",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  }
}
